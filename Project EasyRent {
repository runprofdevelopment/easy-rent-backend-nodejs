// ─── References ───────────────────────────────────────────────────────────────

// Phase 1
Ref: agency_verifications.application_id > agency_applications.id
Ref: users.agency_id > agencies.id
Ref: international_derivers.agency_id > agencies.id
Ref: users.branch_id > branches.id
Ref: role_permissions.role_id > roles.id
Ref: role_permissions.permission_id > permissions.id
Ref: user_roles.user_id > users.id
Ref: user_roles.role_id > roles.id
Ref: otp_verifications.user_id > users.id
Ref: notifications.user_id > users.id
Ref: notification_reads.notification_id > notifications.id
Ref: notification_reads.user_id > users.id
Ref: audit_logs.user_id > users.id
Ref: audit_logs.agency_id > agencies.id

// Phase 2
Ref: branches.agency_id > agencies.id
