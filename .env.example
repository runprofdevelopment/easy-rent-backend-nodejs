# Server
PORT=8080
NODE_ENV=development

# Firebase - Easy Rent Staging
# Get FIREBASE_WEB_API_KEY and FIREBASE_APP_ID from:
# Firebase Console → Project settings → General → Your apps → Web app
FIREBASE_PROJECT_ID=easy-rent-staging
FIREBASE_AUTH_DOMAIN=easy-rent-staging.firebaseapp.com
FIREBASE_STORAGE_BUCKET=easy-rent-staging.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=298070581478
FIREBASE_WEB_API_KEY=
FIREBASE_APP_ID=
GOOGLE_APPLICATION_CREDENTIALS=./credentials/firebase-service-account.json

# Firestore (create database first: Firebase Console → Firestore Database → Create database)
# FIRESTORE_DATABASE_ID=(default)

# Auth
PASSWORD_RESET_REDIRECT_URL=http://localhost:8080
LOGIN_BASE_URL=https://{databaseId}.example.com/{lang}/login

# Email (Nodemailer)
EMAIL_PROVIDER=nodemailer
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=Easy Rent <noreply@example.com>

# Optional: SendGrid
# SENDGRID_API_KEY=

# Optional: Dynalinks
# DYNALINKS_API_KEY=
# DYNALINKS_API_URL=https://dynalinks.app/api/v1/links
